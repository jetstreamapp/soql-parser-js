{
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "declaration": true,
    "isolatedModules": true,
    "lib": ["esnext", "dom"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "rootDir": "src",
    "declarationDir": "dist/types",
    "outDir": "dist",
    "removeComments": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2017"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "test", "docs"]
}
